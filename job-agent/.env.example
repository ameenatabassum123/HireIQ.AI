# Copy this file to `.env` and fill in your key. Never commit `.env`.

# Google Gemini API key - used for resume parsing, JD analysis, resume
# tailoring, and cover-letter generation.
# Free tier: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Session signing secret for web login (generate a long random string)
SESSION_SECRET=change-me-to-a-long-random-string

# Apify token for fallback scrapers
# Get a free token at https://console.apify.com/
APIFY_API_TOKEN=your-apify-token-here
